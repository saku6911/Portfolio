{
  "name": "",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "css:typed": "tcm -e -p src/**/*.scss && yarn format:prettier",
    "css:typed:watch": "tcm -w -e -p src/**/*.scss",
    "deadcode": "ts-prune -e -i  'src/pages|__esModule|Animation*'",
    "deploy": "next build && next export",
    "dev": "next dev",
    "format:prettier": "prettier -w \"./**/*.{ts,tsx,js,jsx,json,css,scss}\"",
    "format:stylelint": "stylelint --fix \"./**/*.{css,scss}\"",
    "lint": "run-s format:** css:typed deadcode lint:** ",
    "lint:eslint": "eslint --quiet \"./**/*.{ts,tsx}\"",
    "lint:tsc": "tsc --noEmit",
    "start": "next start",
    "test": "echo 'Not add test, yet'",
    "prepare": "husky install"
  },
  "dependencies": {
    "next": "^12.1.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^3.2.0",
    "@types/node": "^17.0.18",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "clsx": "^1.1.1",
    "eslint": "^8.9.0",
    "eslint-config-next": "^12.0.10",
    "husky": "^7.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.6",
    "prettier": "^2.5.1",
    "pretty-quick": "^3.1.3",
    "sass": "^1.49.7",
    "stylelint": "^14.5.0",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-recess-order": "^3.0.0",
    "stylelint-config-standard-scss": "^3.0.0",
    "stylelint-prettier": "^2.0.0",
    "ts-prune": "^0.10.3",
    "typed-css-modules": "^0.7.0",
    "typescript": "^4.5.5"
  }
}
